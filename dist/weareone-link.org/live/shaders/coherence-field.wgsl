// ─── Type Aliases ────────────────────────────────────────────────────────
alias float = f32;
alias int = i32;
alias uint = u32;

// ─── Coherence Struct Types ──────────────────────────────────────────────
struct CoherenceFieldState {
    cycle: u32,
    time: f32,
    tau_c: f32,
    entropy: f32,
    osc_position: f32,
    osc_velocity: f32,
    perturb_x: f32,
    perturb_y: f32,
    perturb_energy: f32,
    glyph_opacity: f32,
    glyph_scale: f32,
    glyph_phase: f32,
    glow_intensity: f32,
    glow_radius: f32,
    tone_amplitude: f32,
    total_energy: f32,
    speaking: u32,
    unfurl_progress: f32,
    mouse_x: f32,
    mouse_y: f32,
    resolution_x: f32,
    resolution_y: f32,
    // Identity + Rail state
    identity_level: u32,
    rail_mask: u32,
}

struct VertexOutput {
    @builtin(position) position: vec4f,
    @location(0) uv: vec2f,
}

// ─── Constants from init.glyph.json ──────────────────────────────────────
const GAMMA: f32 = 0.12;       // entropy_tolerance
const K: f32 = 0.1;            // coherence_frequency
const TONE_HZ: f32 = 528.0;    // resonance frequency
const TAU_MIN: f32 = 0.05;     // Law VIII: coherence is conserved
const TAU_MAX: f32 = 0.95;     // Law VI: bounded emergence
const DT: f32 = 0.01666667;    // ~60fps timestep
const PI: f32 = 3.14159265359;
const TWO_PI: f32 = 6.28318530718;

// ─── Safe Math ───────────────────────────────────────────────────────────

fn coh_safe_div(a: f32, b: f32) -> f32 {
    return select(a / b, 0.0, b == 0.0);
}

fn coh_clamp(x: f32, lo: f32, hi: f32) -> f32 {
    return clamp(x, lo, hi);
}

fn coh_pow(a: f32, b: f32) -> f32 {
    return pow(a, b);
}

fn coh_fmod(a: f32, b: f32) -> f32 {
    return a - floor(a / b) * b;
}

// ─── Coherence Field Functions ───────────────────────────────────────────

fn coh_tau(r: f32) -> f32 {
    // tau(r) = e^(-gamma*r) * cos(k*r), clamped to [TAU_MIN, TAU_MAX]
    let raw = exp(-GAMMA * r) * cos(K * r);
    return clamp(raw, TAU_MIN, TAU_MAX);
}

fn coh_oscillator_force(pos: f32, vel: f32) -> f32 {
    // Damped Helmholtz: F = -k*x - gamma*v
    return -K * pos - GAMMA * vel;
}

fn coh_oscillator_energy(pos: f32, vel: f32) -> f32 {
    // E = 0.5*k*x^2 + 0.5*v^2 (conserved minus damping)
    return 0.5 * K * pos * pos + 0.5 * vel * vel;
}

// ─── Coherence Energy Helpers ────────────────────────────────────────────

fn coh_kl_term(p: f32, q: f32) -> f32 {
    if (p <= 0.0) { return 0.0; }
    let q_safe = max(q, 1e-30);
    return p * log(p / q_safe);
}

fn coh_coherence_energy(kB_T: f32, dkl: f32) -> f32 {
    return kB_T * dkl;
}

fn coh_maintenance_power(kB_T: f32, gamma: f32, dkl: f32) -> f32 {
    return kB_T * gamma * dkl;
}

fn coh_damkohler(gamma: f32, L: f32, D: f32) -> f32 {
    return select(gamma * L * L / D, 0.0, D == 0.0);
}

// ─── Forgetting Curve Models ─────────────────────────────────────────────

fn coh_forget_ebbinghaus(t: f32, S: f32) -> f32 {
    return exp(-t / max(S, 1.0));
}

fn coh_forget_power(t: f32, d: f32) -> f32 {
    return pow(1.0 + t, -d);
}

// ─── Noise Functions (for organic visual texture) ────────────────────────

fn hash21(p: vec2f) -> f32 {
    let h = dot(p, vec2f(127.1, 311.7));
    return fract(sin(h) * 43758.5453123);
}

fn noise2d(p: vec2f) -> f32 {
    let i = floor(p);
    let f = fract(p);
    let u = f * f * (3.0 - 2.0 * f); // smoothstep
    return mix(
        mix(hash21(i + vec2f(0.0, 0.0)), hash21(i + vec2f(1.0, 0.0)), u.x),
        mix(hash21(i + vec2f(0.0, 1.0)), hash21(i + vec2f(1.0, 1.0)), u.x),
        u.y
    );
}

fn fbm(p: vec2f, octaves: i32) -> f32 {
    var value: f32 = 0.0;
    var amplitude: f32 = 0.5;
    var frequency: f32 = 1.0;
    var pos = p;
    for (var i: i32 = 0; i < octaves; i++) {
        value += amplitude * noise2d(pos * frequency);
        amplitude *= 0.5;
        frequency *= 2.0;
    }
    return value;
}


// ─── Coherence Field Compute Shader ──────────────────────────────────────
// Advances the coherence field by one timestep.
// Runs on the GPU at 60fps. This is real physics, not animation.

@group(0) @binding(0) var<storage, read_write> field: CoherenceFieldState;

@compute @workgroup_size(1)
fn field_step(@builtin(global_invocation_id) id: vec3u) {
    // Advance soul clock
    field.cycle += 1u;
    field.time += DT;

    // ─── Damped Helmholtz Oscillator ─────────────────────────────
    let force = coh_oscillator_force(field.osc_position, field.osc_velocity);
    field.osc_velocity += force * DT;
    field.osc_position += field.osc_velocity * DT;

    // ─── Tau from oscillator state ───────────────────────────────
    field.tau_c = coh_tau(abs(field.osc_position));

    // ─── Perturbation decay ──────────────────────────────────────
    field.perturb_energy *= 0.92;

    // ─── Glyph visual state from field ───────────────────────────
    field.glyph_opacity = clamp(
        0.5 + 0.3 * field.tau_c + 0.15 * field.perturb_energy,
        0.3, 0.95
    );

    let base_scale = 1.0 + 0.08 * field.osc_position - 0.03 * field.perturb_energy;

    // ─── Unfurl ──────────────────────────────────────────────────
    if (field.speaking == 1u) {
        field.unfurl_progress += (1.0 - field.unfurl_progress) * 0.03;
        field.glyph_scale = clamp(base_scale * (0.7 + 0.3 * (1.0 - field.unfurl_progress)), 0.5, 1.2);
    } else {
        field.unfurl_progress *= 0.98;
        field.glyph_scale = clamp(base_scale, 0.5, 1.2);
    }

    // ─── Phase + Glow ────────────────────────────────────────────
    field.glyph_phase += K * DT;
    field.glow_intensity = 0.08 + 0.06 * field.tau_c + 0.05 * field.perturb_energy;
    field.glow_radius = 1.0 + 0.2 * field.tau_c;

    // ─── Tone amplitude ──────────────────────────────────────────
    field.tone_amplitude = field.tau_c * 0.15;

    // ─── Entropy ─────────────────────────────────────────────────
    field.entropy = GAMMA * abs(field.osc_velocity);

    // ─── Energy conservation check (Law VIII) ────────────────────
    field.total_energy = coh_oscillator_energy(field.osc_position, field.osc_velocity)
        + field.perturb_energy;
}

// ─── Perturbation injection ──────────────────────────────────────────────
// Called when observer interacts (mouse/touch)

@compute @workgroup_size(1)
fn inject_perturbation(@builtin(global_invocation_id) id: vec3u) {
    field.osc_velocity += field.perturb_energy * 0.3;
}


